{
    "layer": "top",
    "position": "top",
    "margin-top": 5,
    "margin-left": 10,
    "margin-right": 10,
    "height": 35,
    "modules-left": [
        "hyprland/workspaces",
        "mpris"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "pulseaudio",
        "network",
        "cpu",
        "memory",
        "custom/weather",
        "clock",
        "custom/powermenu"
    ],
    "hyprland/window": {
        "format": "{title}",
        "max-length": 40,
        "rewrite": {
            "": "󰣇 Hyprland",
            "(.*) — Mozilla Firefox": "󰈹 $1",
            "(.*) - Google Chrome": "󰊯 $1",
            "(.*) - Chromium": "󰊯 $1",
            "(.*) - Visual Studio Code": "󰨞 $1",
            "(.*) - VSCodium": "󰨞 $1",
            "vim (.*)": " $1",
            "nvim (.*)": " $1",
            "(.*) - Discord": "󰙯 $1",
            "Telegram (.*)": "󰔁 $1",
            "Spotify(.*)": "󰓇 Spotify",
            "(.*) - VLC media player": "󰕼 $1",
            "Alacritty": " Terminal",
            "kitty": " Terminal",
            "foot": " Terminal",
            "zsh": " Terminal",
            "Dolphin": "󰉋 Files",
            "thunar": "󰉋 Files",
            "nautilus": "󰉋 Files",
            "Steam": "󰓓 Steam",
            "OBS(.*)": "󰑋 OBS",
            "GIMP(.*)": "󰏘 GIMP",
            "Blender(.*)": "󰂫 Blender"
        },
        "separate-outputs": true
    },
    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": 4,
            "HDMI-A-1": 3
        }
    },
    "custom/powermenu": {
        "format": "󰤆",
        "tooltip": false,
        "on-click": "~/.config/rofi/powermenu/type-6/powermenu.sh &"
    },
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
        "interval": 1,
        "format": " {usage:2}%",
        "tooltip": true
    },
    "memory": {
        "interval": 1,
        "format": "󰰑 {percentage:2}%",
        "tooltip-format": "内存: {used:0.1f}GB / {total:0.1f}GB"
    },
    "network": {
        "interval": 1,
        "format": "󰇚 {bandwidthDownBits} 󰕒 {bandwidthUpBits}",
        "format-disconnected": "󰖪 断开",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n下载: {bandwidthDownBits}\n上传: {bandwidthUpBits}"
    },
    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} <i>{dynamic}</i>",
        "player-icons": {
            "default": "▶",
            "spotify": "󰓇"
        },
        "status-icons": {
            "paused": "󰏤"
        },
        "dynamic-order": [
            "title",
            "artist"
        ],
        "dynamic-len": 40,
        "dynamic-separator": " - ",
        "ignored-players": [
            "firefox"
        ],
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous",
        "tooltip-format": "{player}: {title} - {artist}\n{album}",
        "tooltip-format-paused": "{player}: {title} - {artist}\n{album} (Paused)"
    },
    "custom/weather": {
        "exec": "~/.config/waybar/scripts/weather.sh",
        "return-type": "json",
        "interval": 1800,
        "tooltip": true
    },
    "pulseaudio": {
        "format": "󰕾",
        "format-bluetooth": "{volume}% {icon} {format_source}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": "󰖁",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": [
                "",
                "",
                ""
            ]
        },
        "on-click": "swayosd-client --output-volume mute-toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "swayosd-client --output-volume raise",
        "on-scroll-down": "swayosd-client --output-volume lower"
    }
}
