{
    "layer": "top",
    "position": "top",
    "margin-top": 8,
    "margin-left": 14,
    "margin-right": 14,
    "height": 36,
    "modules-left": [
        "hyprland/workspaces",
        "mpris"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "pulseaudio",
        "network",
        "bluetooth",
        "clock",
        "custom/powermenu"
    ],
    "hyprland/window": {
        "format": "{title}",
        "max-length": 36,
        "rewrite": {
            "": "󰣇 Hyprland",
            "(.*) — Mozilla Firefox": "󰈹 $1",
            "(.*) - Google Chrome": "󰊯 $1",
            "(.*) - Chromium": "󰊯 $1",
            "(.*) - Visual Studio Code": "󰨞 $1",
            "(.*) - VSCodium": "󰨞 $1",
            "vim (.*)": " $1",
            "nvim (.*)": " $1",
            "(.*) - Discord": "󰙯 $1",
            "Telegram (.*)": "󰔁 $1",
            "Spotify(.*)": "󰓇 Spotify",
            "(.*) - VLC media player": "󰕼 $1",
            "Alacritty": " Terminal",
            "kitty": " Terminal",
            "foot": " Terminal",
            "zsh": " Terminal",
            "Dolphin": "󰉋 Files",
            "thunar": "󰉋 Files",
            "nautilus": "󰉋 Files",
            "Steam": "󰓓 Steam",
            "OBS(.*)": "󰑋 OBS",
            "GIMP(.*)": "󰏘 GIMP",
            "Blender(.*)": "󰂫 Blender"
        },
        "separate-outputs": true
    },
    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "sort-by-number": true
    },
    "custom/powermenu": {
        "format": "󰤆",
        "tooltip": false,
        "on-click": "~/.config/rofi/powermenu/type-6/powermenu.sh &"
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%a %b %-d  %H:%M}",
        "tooltip-format": "<span color='#6E695C'>{:%B %Y}</span>\n<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#3E3A32'><b>{}</b></span>",
                "days": "<span color='#6E695C'>{}</span>",
                "weekdays": "<span color='#97783C'>{}</span>",
                "today": "<span color='#A85049'><b>{}</b></span>"
            }
        }
    },
    "network": {
        "interface": "wlp3s0",
        "interval": 5,
        "format": "󰈀",
        "format-wifi": "{icon}",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰖪",
        "format-disabled": "󰖪",
        "format-icons": [
            "󰤯",
            "󰤟",
            "󰤢",
            "󰤥",
            "󰤨"
        ],
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ifname}: {ipaddr}/{cidr}",
        "tooltip-format-ethernet": "Wired\n{ifname}: {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected",
        "tooltip-format-disabled": "Wi-Fi off",
        "on-click": "systemsettings kcm_networkmanagement"
    },
    "bluetooth": {
        "format": "󰂯",
        "format-disabled": "󰂲",
        "format-off": "󰂲",
        "format-on": "󰂯",
        "format-connected": "󰂱",
        "format-no-controller": "󰂲",
        "tooltip-format": "Bluetooth: {status}",
        "tooltip-format-connected": "{num_connections} device(s) connected",
        "on-click": "systemsettings kcm_bluetooth"
    },
    "mpris": {
        "format": "{player_icon}  {dynamic}",
        "format-paused": "{status_icon}  {dynamic}",
        "player-icons": {
            "default": "󰝚",
            "spotify": "󰓇"
        },
        "status-icons": {
            "paused": "󰏤"
        },
        "dynamic-order": [
            "title",
            "artist"
        ],
        "dynamic-len": 30,
        "dynamic-separator": " · ",
        "ignored-players": [
            "firefox"
        ],
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous",
        "tooltip-format": "{player}: {title} - {artist}\n{album}",
        "tooltip-format-paused": "{player}: {title} - {artist}\n{album} (paused)"
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-bluetooth": "{icon}",
        "format-muted": "󰖁",
        "format-source": "",
        "format-source-muted": "",
        "tooltip-format": "{desc}\nVolume {volume}%",
        "format-icons": {
            "headphone": "󰋋",
            "hands-free": "󰋎",
            "headset": "󰋎",
            "phone": "󰄜",
            "portable": "󰄜",
            "car": "󰄋",
            "default": [
                "󰕿",
                "󰖀",
                "󰕾"
            ]
        },
        "on-click": "swayosd-client --output-volume mute-toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "swayosd-client --output-volume raise",
        "on-scroll-down": "swayosd-client --output-volume lower"
    }
}
