{
    "layer": "top",
    "position": "top",
    "margin-top": 8,
    "margin-left": 14,
    "margin-right": 14,
    "height": 36,
    "modules-left": [
        "hyprland/workspaces",
        "mpris"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "pulseaudio",
        "network",
        "bluetooth",
        "custom/airpods",
        "clock",
        "custom/powermenu"
    ],
    "hyprland/window": {
        "format": "{title}",
        "max-length": 36,
        "rewrite": {
            "": "󰣇 Hyprland",
            "(.*) — Mozilla Firefox": "󰈹 $1",
            "(.*) - Google Chrome": "󰊯 $1",
            "(.*) - Chromium": "󰊯 $1",
            "(.*) - Visual Studio Code": "󰨞 $1",
            "(.*) - VSCodium": "󰨞 $1",
            "vim (.*)": " $1",
            "nvim (.*)": " $1",
            "(.*) - Discord": "󰙯 $1",
            "Telegram (.*)": "󰔁 $1",
            "Spotify(.*)": "󰓇 Spotify",
            "(.*) - VLC media player": "󰕼 $1",
            "Alacritty": " Terminal",
            "kitty": " Terminal",
            "foot": " Terminal",
            "zsh": " Terminal",
            "Dolphin": "󰉋 Files",
            "thunar": "󰉋 Files",
            "nautilus": "󰉋 Files",
            "Steam": "󰓓 Steam",
            "OBS(.*)": "󰑋 OBS",
            "GIMP(.*)": "󰏘 GIMP",
            "Blender(.*)": "󰂫 Blender"
        },
        "separate-outputs": true
    },
    "hyprland/workspaces": {
        "format": "{windows}",
        "format-window-separator": "  ",
        "window-rewrite-default": "󰣆",
        "window-rewrite": {
            "class<wechat(\\.exe)?|WeChat>": "󰘑",
            "class<QQ|qq>": "󰘅",
            "class<firefox|librewolf|floorp|zen(-browser)?>": "󰈹",
            "class<google-chrome|Chromium|chromium|brave-browser|vivaldi.*>": "󰊯",
            "class<microsoft-edge.*|Microsoft-edge.*>": "󰇩",
            "class<chrome-.*>": "󰖟",
            "class<Code|code-url-handler|VSCodium|codium|cursor>": "󰨞",
            "class<jetbrains-(.*)>": "",
            "class<neovide>": "",
            "class<sublime_text>": "󰅳",
            "class<obsidian>": "󰠮",
            "class<com.mitchellh.ghostty>": "󰊠",
            "class<kitty|Alacritty|foot|org.wezfurlong.wezterm|konsole>": "",
            "class<Spotify|spotify>": "󰓇",
            "class<netease-cloud-music|yesplaymusic|youtube-music>": "󰝚",
            "class<discord|WebCord|vesktop>": "󰙯",
            "class<org.telegram.desktop|Telegram>": "󰔁",
            "class<Slack>": "󰒱",
            "class<whatsapp.*|WhatsApp.*>": "󰖣",
            "class<teams.*|Microsoft Teams.*>": "󰊻",
            "class<Zoom|zoom>": "󰕧",
            "class<Signal>": "󰭹",
            "class<thunderbird|evolution|org.gnome.Evolution>": "󰇮",
            "class<vlc>": "󰕼",
            "class<mpv>": "",
            "class<com.obsproject.Studio>": "󰑋",
            "class<kdenlive|org.kde.kdenlive>": "󰕧",
            "class<Gimp.*|gimp|krita|Inkscape|org.inkscape.Inkscape>": "󰏘",
            "class<darktable>": "󰄀",
            "class<Blender|blender>": "󰂫",
            "class<org.kde.dolphin|thunar|org.gnome.Nautilus|nemo|pcmanfm.*>": "󰉋",
            "class<org.pwmt.zathura|okular|org.kde.okular|evince|org.gnome.Evince>": "󰈦",
            "class<libreoffice.*|soffice.*>": "󰈬",
            "class<steam>": "󰓓",
            "class<lutris|heroic|net.retrodeck.*|retroarch>": "󰊖",
            "class<qbittorrent|org.qbittorrent.qBittorrent|transmission.*>": "󰇚",
            "class<virt-manager|VirtualBox.*>": "󰍹",
            "class<pavucontrol|org.pulseaudio.pavucontrol>": "󰕾",
            "class<systemsettings|nwg-look|org.gnome.Settings>": "",
            "class<.*\\.exe>": "󰖳"
        },
        "on-click": "activate",
        "sort-by-number": true
    },
    "custom/powermenu": {
        "format": "󰤆",
        "tooltip": false,
        "on-click": "~/.config/rofi/powermenu/type-6/powermenu.sh &"
    },
    "custom/airpods": {
        "exec": "~/.config/waybar/scripts/airpods.sh",
        "return-type": "json",
        "interval": 15,
        "format": "󱡏 {}",
        "hide-empty-text": true,
        "on-click": "~/.config/waybar/scripts/airpods.sh activate"
    },
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%a %b %-d  %H:%M}",
        "tooltip-format": "<span color='#6E695C'>{:%B %Y}</span>\n<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#3E3A32'><b>{}</b></span>",
                "days": "<span color='#6E695C'>{}</span>",
                "weekdays": "<span color='#97783C'>{}</span>",
                "today": "<span color='#A85049'><b>{}</b></span>"
            }
        }
    },
    "network": {
        "interface": "wlp3s0",
        "interval": 5,
        "format": "󰈀",
        "format-wifi": "{icon}",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰖪",
        "format-disabled": "󰖪",
        "format-icons": [
            "󰤯",
            "󰤟",
            "󰤢",
            "󰤥",
            "󰤨"
        ],
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ifname}: {ipaddr}/{cidr}",
        "tooltip-format-ethernet": "Wired\n{ifname}: {ipaddr}/{cidr}",
        "tooltip-format-disconnected": "Disconnected",
        "tooltip-format-disabled": "Wi-Fi off",
        "on-click": "systemsettings kcm_networkmanagement"
    },
    "bluetooth": {
        "format": "󰂯",
        "format-disabled": "󰂲",
        "format-off": "󰂲",
        "format-on": "󰂯",
        "format-connected": "󰂱",
        "format-no-controller": "󰂲",
        "tooltip-format": "Bluetooth: {status}",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}",
        "on-click": "systemsettings kcm_bluetooth"
    },
    "mpris": {
        "format": "󰝚  {dynamic}",
        "format-paused": "󰏤  {dynamic}",
        "dynamic-order": [
            "title",
            "artist"
        ],
        "dynamic-len": 30,
        "dynamic-separator": " · ",
        "ignored-players": [
            "firefox"
        ],
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-click-middle": "playerctl previous",
        "tooltip-format": "{player}: {title} - {artist}\n{album}",
        "tooltip-format-paused": "{player}: {title} - {artist}\n{album} (paused)"
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-bluetooth": "{icon}",
        "format-muted": "󰖁",
        "format-source": "",
        "format-source-muted": "",
        "tooltip-format": "{desc}\nVolume {volume}%",
        "format-icons": {
            "headphone": "󰋋",
            "hands-free": "󰋎",
            "headset": "󰋎",
            "phone": "󰄜",
            "portable": "󰄜",
            "car": "󰄋",
            "default": [
                "󰕿",
                "󰖀",
                "󰕾"
            ]
        },
        "on-click": "swayosd-client --output-volume mute-toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "swayosd-client --output-volume raise",
        "on-scroll-down": "swayosd-client --output-volume lower"
    }
}
