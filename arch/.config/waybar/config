{
    "layer": "top",
    "position": "top",
    "margin-top" : 5,
    "margin-left": 10,
    "margin-right": 10,
    "height" : 35,
    "modules-left": [
      "hyprland/workspaces",
    ],
    "modules-center": [
      "hyprland/window"
    ],
    "modules-right": [
    "battery",
    "pulseaudio",
    "network",
    "temperature",
    "clock",
    "custom/powermenu",
    ],
    "hyprland/window": {
      "format": "{title}",
      "max-length": 40,
      "rewrite": {
        "": "≤░μΘ Hyprland",
        "(.*) έΑΦ Mozilla Firefox": "≤░Ι╣ $1",
        "(.*) - Google Chrome": "≤░Λψ $1",
        "(.*) - Chromium": "≤░Λψ $1",
        "(.*) - Visual Studio Code": "≤░ρη $1",
        "(.*) - VSCodium": "≤░ρη $1",
        "vim (.*)": " $1",
        "nvim (.*)": " $1",
        "(.*) - Discord": "≤░βψ $1",
        "Telegram (.*)": "≤░ΦΒ $1",
        "Spotify(.*)": "≤░ΥΘ Spotify",
        "(.*) - VLC media player": "≤░Χ╝ $1",
        "Alacritty": " Terminal",
        "kitty": " Terminal",
        "foot": " Terminal",
        "zsh": " Terminal",
        "Dolphin": "≤░ΚΜ Files",
        "thunar": "≤░ΚΜ Files",
        "nautilus": "≤░ΚΜ Files",
        "Steam": "≤░ΥΥ Steam",
        "OBS(.*)": "≤░ΣΜ OBS",
        "GIMP(.*)": "≤░Πα GIMP",
        "Blender(.*)": "≤░Γτ Blender"
      },
      "separate-outputs": true
    },
    "hyprland/workspaces": {
      "format": "{name}",
      "on-click": "activate",
      "sort-by-number": true,
      "persistent-workspaces": {
        "*": 4,
        "HDMI-A-1": 3
      },
    },
    "custom/powermenu": {
        "format": "≤░νΗ",
        "tooltip": false,
        "on-click": "~/.config/rofi/powermenu/type-6/powermenu.sh &"
    },
    "clock": {
      "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "{:%Y-%m-%d}"
    },
    "cpu": {
      "format": "  {usage}%",
      "tooltip": false
    },
    "memory": {
      "format": "{}% ΎΔΚ "
    },
    "temperature": {
      "critical-threshold": 80,
      "format": "{icon} {temperatureC}┬░C",
      "format-icons": ["Ύζτ", "ΎΜΚ", "Ύζσ"]
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon}  {capacity}%",
      "format-full": "{icon}  {capacity}%",
      "format-charging": "ΎΩπ  {capacity}%",
      "format-plugged": "ΎΘο  {capacity}%",
      "format-alt": "{time} {icon}",
      "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "network": {
      "format-wifi": "ΎΘτ  {signalStrength}%",
      "format-ethernet": "{cidr} ΎηΨ",
      "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
      "format-linked": "{ifname} (No IP) ΎηΨ",
      "format-disconnected": " έγι ",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
      "format": "{icon}  {volume}%",
      "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
      "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
      "format-muted": "Ύγσ {format_source}",
      "format-icons": {
        "headphone": "ΎΑξ",
        "hands-free": "ΎΨΡ",
        "headset": "ΎΨΡ",
        "phone": "ΎΓΧ",
        "portable": "ΎΓΧ",
        "car": "ΎΗ╣",
        "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
      },
      "on-click": "pavucontrol"
    },
}
